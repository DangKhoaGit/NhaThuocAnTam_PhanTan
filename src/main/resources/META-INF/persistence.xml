<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="mariadb-pu">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.antam.app.entity.ChiTietHoaDon</class>
        <class>com.antam.app.entity.ChiTietPhieuDatThuoc</class>
        <class>com.antam.app.entity.ChiTietPhieuNhap</class>
        <class>com.antam.app.entity.LoThuoc</class>
        <class>com.antam.app.entity.DangDieuChe</class>
        <class>com.antam.app.entity.DonViTinh</class>
        <class>com.antam.app.entity.HoaDon</class>
        <class>com.antam.app.entity.Ke</class>
        <class>com.antam.app.entity.KhachHang</class>
        <class>com.antam.app.entity.KhuyenMai</class>
        <class>com.antam.app.entity.LoaiKhuyenMai</class>
        <class>com.antam.app.entity.NhanVien</class>
        <class>com.antam.app.entity.PhienNguoiDung</class>
        <class>com.antam.app.entity.PhieuDatThuoc</class>
        <class>com.antam.app.entity.PhieuNhap</class>
        <class>com.antam.app.entity.ThongKeDoanhThu</class>
        <class>com.antam.app.entity.Thuoc</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.mariadb.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mariadb://localhost:3306/QuanLyTimThuoc"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="sapassword"/>
            <property name="jakarta.persistence.jdbc.dialect" value="org.hibernate.dialect.MariaDBDialect"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
        </properties>
    </persistence-unit>
</persistence>
